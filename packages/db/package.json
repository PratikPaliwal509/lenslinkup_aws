{
  "name": "@lenslinkup/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma.config.ts",
    "db:push": "prisma db push --config prisma.config.ts",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "prisma studio --config prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.5.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "prisma": "^7.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  }
}
